---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign html_pages = site.pages | sort: "url" %}
{% for page in html_pages %}
  {% if page.url and page.name != "sitemap.xml" and page.sitemap != false %}
  <url>
    <loc>{{ page.url | replace: 'index.html', '' | absolute_url }}</loc>
  </url>
  {% endif %}
{% endfor %}
{% for post in site.posts %}
  {% unless post.private_review or post.sitemap == false %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
  {% endunless %}
{% endfor %}
{% assign static_files_sorted = site.static_files | sort: "path" %}
{% for file in static_files_sorted %}
  {% if file.path contains '/legacy/' and file.extname == '.html' %}
  <url>
    <loc>{{ file.path | replace: 'index.html', '' | absolute_url }}</loc>
  </url>
  {% endif %}
{% endfor %}
</urlset>
